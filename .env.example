COMPOSE_PROJECT_NAME=personal-blog
HTTP_PORT=80

MYSQL_DATABASE=personal_blog
MYSQL_USERNAME=blog
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-password

REDIS_USERNAME=default
REDIS_PASSWORD=change-redis-password

SPRING_PROFILES_ACTIVE=docker

JWT_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
SECURE_COOKIES=false
ADMIN_ALLOWED_ORIGINS=http://localhost,http://admin.localhost

# Used once when sys_user is empty. Remove after the first successful login.
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=change-this-before-starting
ADMIN_INITIAL_NICKNAME=Administrator

# Alibaba Cloud OSS (server-side only; use a least-privilege RAM user).
# Example region/endpoint: cn-hangzhou / https://oss-cn-hangzhou.aliyuncs.com
OSS_REGION=
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_CDN_DOMAIN=
OSS_OBJECT_PREFIX=blog/dev
OSS_ORPHAN_GRACE_PERIOD=24h
OSS_DELETE_RETRY_BASE_DELAY=1m
OSS_STALE_DELETE_TIMEOUT=15m
OSS_CLEANUP_BATCH_SIZE=50
OSS_CLEANUP_INTERVAL=300000
MAIL_ENABLED=false
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_SMTP_AUTH=true
MAIL_STARTTLS=true
BLOG_PROJECT=blog
BLOG_ENVIRONMENT=prod
CACHE_ENABLED=true
ARTICLE_CACHE_TTL=10m
LIST_CACHE_TTL=5m
TAXONOMY_CACHE_TTL=30m
STATISTICS_FLUSH_INTERVAL=60000
SWAGGER_ENABLED=true
# Public site
SITE_URL=http://localhost
